{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/accordion-item",
	"version": "1.0.0",
	"title": "Accordion Item",
	"category": "layout",
	"icon": "arrow-down-alt2",
	"description": "A single accordion panel (<details>/<summary>) — must be inside an Accordion block.",
	"keywords": [ "accordion", "faq", "collapse", "details" ],
	"textdomain": "goblocks",
	"parent": [ "goblocks/accordion" ],
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false,
		"inserter":        false
	},
	"attributes": {
		"uniqueId":       { "type": "string",  "default": "" },
		"styles":         { "type": "object",  "default": {} },
		"globalClasses":  { "type": "array",   "items": { "type": "string" }, "default": [] },
		"htmlAttributes": { "type": "object",  "default": {} },
		"dynamicContent": { "type": "object",  "default": {} },
		"generatedCss":   { "type": "string",  "default": "" },
		"blockVersion":   { "type": "integer", "default": 1 },
		"question":       { "type": "string",  "default": "" },
		"isOpen":         { "type": "boolean", "default": false }
	},
	"usesContext": [ "goblocks/accordionFaqSchema" ],
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css"
}
