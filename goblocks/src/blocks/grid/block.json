{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/grid",
	"version": "1.0.0",
	"title": "Grid",
	"category": "layout",
	"icon": "grid-view",
	"description": "CSS grid layout container with responsive column builder.",
	"keywords": [ "grid", "columns", "layout", "css grid" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"usesContext": [ "postId", "postType", "queryId" ],
	"attributes": {
		"uniqueId":       { "type": "string",  "default": "" },
		"tagName":        { "type": "string",  "default": "div" },
		"styles":         { "type": "object",  "default": {} },
		"globalClasses":  { "type": "array",   "items": { "type": "string" }, "default": [] },
		"htmlAttributes": { "type": "object",  "default": {} },
		"dynamicContent": { "type": "object",  "default": {} },
		"generatedCss":   { "type": "string",  "default": "" },
		"blockVersion":   { "type": "integer", "default": 1 }
	},
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css"
}
