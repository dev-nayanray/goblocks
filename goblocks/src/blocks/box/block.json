{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "goblocks/box",
	"version": "1.0.0",
	"title": "Box",
	"category": "layout",
	"icon": "layout",
	"description": "Universal layout container with full flex, grid, background, and responsive controls.",
	"keywords": [ "container", "wrapper", "layout", "flex", "grid", "section", "div" ],
	"textdomain": "goblocks",
	"supports": {
		"html":            false,
		"customClassName": false,
		"className":       false,
		"anchor":          false
	},
	"usesContext": [ "postId", "postType", "queryId" ],
	"providesContext": {
		"goblocks/boxUniqueId": "uniqueId"
	},
	"attributes": {
		"uniqueId":    { "type": "string",  "default": "" },
		"tagName":     { "type": "string",  "default": "div" },
		"styles":      { "type": "object",  "default": {} },
		"globalClasses": { "type": "array", "items": { "type": "string" }, "default": [] },
		"htmlAttributes": { "type": "object", "default": {} },
		"dynamicContent": { "type": "object", "default": {} },
		"generatedCss":   { "type": "string",  "default": "" },
		"blockVersion":   { "type": "integer", "default": 1 },
		"link":           { "type": "string",  "default": "" },
		"linkTarget":     { "type": "string",  "default": "_self" },
		"linkRel":        { "type": "string",  "default": "" },
		"ariaLabel":      { "type": "string",  "default": "" },
		"animationClass": { "type": "string",  "default": "" }
	},
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"style":        "file:./style-index.css",
	"render":       "file:./render.php"
}
